{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['nickname', 'cleanNickname', 'email', 'saldo', 'games', 'totalPairs', 'best', 'profit', 'createdAt', 'updatedAt'])",

        "nickname": {
          ".validate": "newData.isString() && newData.val().length >= 3 && newData.val().length <= 20"
        },
        "cleanNickname": {
          ".validate": "newData.isString() && newData.val().matches(/^[a-z0-9_]{3,16}$/)"
        },
        "email": {
          ".validate": "newData.isString() && newData.val().length <= 120"
        },
        "avatar": {
          ".validate": "newData.isString() && newData.val().length <= 120"
        },
        "ownedCardSkins": {
          ".validate": true
        },
        "selectedCardSkin": {
          ".validate": "newData.isString() && newData.val().matches(/^(default|galaxy|arcane|forest|storm|royal|inferno|radiant|tech)$/)"
        },
        "saldo": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000000"
        },
        "games": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "totalPairs": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "best": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 8"
        },
        "profit": {
          ".validate": "newData.isNumber()"
        },
        "trophies": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "cups": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "medals": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "silverCups": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "goldCups": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "createdAt": {
          ".validate": "newData.isNumber() && newData.val() <= now + 300000"
        },
        "updatedAt": {
          ".validate": "newData.isNumber() && newData.val() <= now + 300000"
        },
        "$other": {
          ".validate": false
        }
      }
    },

    "nicknames": {
      "$nickname": {
        ".read": "auth != null",
        ".write": "auth != null && ((!data.exists() && newData.val() === auth.uid) || (data.val() === auth.uid && (!newData.exists() || newData.val() === auth.uid)))",
        ".validate": "!newData.exists() || ($nickname.matches(/^[a-z0-9_]{3,16}$/) && newData.isString() && newData.val() === auth.uid)"
      }
    },

    "ranking": {
      ".read": true,
      ".indexOn": ["tiempoMs", "pares", "t"],
      "$uid": {
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['uid', 'user', 'tiempoMs', 'segundos', 'intentos', 'pares', 'premio', 't']) && newData.child('uid').val() === $uid",
        "uid": { ".validate": "newData.isString() && newData.val() === $uid" },
        "user": { ".validate": "newData.isString() && newData.val().length >= 3 && newData.val().length <= 20" },
        "tiempoMs": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "segundos": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "intentos": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 10" },
        "pares": { ".validate": "newData.isNumber() && newData.val() >= 8 && newData.val() <= 8" },
        "premio": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "avatar": { ".validate": "newData.isString() && newData.val().length <= 120" },
        "t": { ".validate": "newData.isNumber() && newData.val() <= now + 300000" },
        "$other": { ".validate": false }
      }
    },

    "leaderboard": {
      ".read": true,
      ".indexOn": ["tiempoMs", "pares", "t"],
      "$entry": {
        ".write": "auth != null && newData.child('uid').val() === auth.uid",
        ".validate": "newData.hasChildren(['uid', 'user', 'tiempoMs', 'segundos', 'intentos', 'pares', 'premio', 't'])",
        "uid": { ".validate": "newData.isString() && newData.val() === auth.uid" },
        "user": { ".validate": "newData.isString() && newData.val().length >= 3 && newData.val().length <= 20" },
        "tiempoMs": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "segundos": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "intentos": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 10" },
        "pares": { ".validate": "newData.isNumber() && newData.val() >= 8 && newData.val() <= 8" },
        "premio": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "avatar": { ".validate": "newData.isString() && newData.val().length <= 120" },
        "t": { ".validate": "newData.isNumber() && newData.val() <= now + 300000" },
        "$other": { ".validate": false }
      }
    },

    "rankingMedals": {
      ".read": true,
      "$uid": {
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "!newData.exists() || (newData.hasChildren(['uid', 'user', 'cups', 't']) && newData.child('uid').val() === $uid)",
        "uid": { ".validate": "newData.isString() && newData.val() === $uid" },
        "user": { ".validate": "newData.isString() && newData.val().length >= 3 && newData.val().length <= 20" },
        "avatar": { ".validate": "newData.isString() && newData.val().length <= 120" },
        "cups": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "t": { ".validate": "newData.isNumber() && newData.val() <= now + 300000" },
        "$other": { ".validate": false }
      }
    },

    "rankingCups": {
      ".read": true,
      "$uid": {
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "!newData.exists() || (newData.hasChildren(['uid', 'user', 'cups', 't']) && newData.child('uid').val() === $uid)",
        "uid": { ".validate": "newData.isString() && newData.val() === $uid" },
        "user": { ".validate": "newData.isString() && newData.val().length >= 3 && newData.val().length <= 20" },
        "avatar": { ".validate": "newData.isString() && newData.val().length <= 120" },
        "cups": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "t": { ".validate": "newData.isNumber() && newData.val() <= now + 300000" },
        "$other": { ".validate": false }
      }
    },

    "historial": {
      ".read": true,
      ".indexOn": ["t"],
      "$entry": {
        ".write": "auth != null && newData.child('uid').val() === auth.uid",
        ".validate": "newData.hasChildren(['uid', 'user', 'pares', 'intentos', 'net', 't'])",
        "uid": { ".validate": "newData.isString() && newData.val() === auth.uid" },
        "user": { ".validate": "newData.isString() && newData.val().length >= 3 && newData.val().length <= 20" },
        "pares": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 8" },
        "intentos": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 10" },
        "net": { ".validate": "newData.isNumber()" },
        "avatar": { ".validate": "newData.isString() && newData.val().length <= 120" },
        "t": { ".validate": "newData.isNumber() && newData.val() <= now + 300000" },
        "$other": { ".validate": false }
      }
    },

    "liveHistory": {
      ".read": true,
      ".indexOn": ["t"],
      "$entry": {
        ".write": "auth != null && newData.child('uid').val() === auth.uid",
        ".validate": "newData.hasChildren(['uid', 'user', 'pares', 'intentos', 'net', 't'])",
        "uid": { ".validate": "newData.isString() && newData.val() === auth.uid" },
        "user": { ".validate": "newData.isString() && newData.val().length >= 3 && newData.val().length <= 20" },
        "pares": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 8" },
        "intentos": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 10" },
        "net": { ".validate": "newData.isNumber()" },
        "avatar": { ".validate": "newData.isString() && newData.val().length <= 120" },
        "t": { ".validate": "newData.isNumber() && newData.val() <= now + 300000" },
        "$other": { ".validate": false }
      }
    },

    "onlineRooms": {
      ".read": "auth != null",
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null && ((!data.exists() && newData.child('hostUid').val() === auth.uid && newData.child('players').child(auth.uid).exists()) || (data.exists() && data.child('players').child(auth.uid).exists()) || (newData.exists() && newData.child('players').child(auth.uid).exists()))",
        ".validate": "!newData.exists() || (newData.hasChildren(['id', 'mode', 'status', 'players', 'hostUid', 'createdAt', 'updatedAt']) && newData.child('id').val() === $roomId)",

        "id": { ".validate": "newData.isString() && newData.val() === $roomId" },
        "mode": { ".validate": "newData.val() === 'classic' || newData.val() === 'memory'" },
        "wager": { ".validate": "newData.isNumber() && (newData.val() === 0 || newData.val() === 500 || newData.val() === 1000 || newData.val() === 2500 || newData.val() === 5000 || newData.val() === 10000 || newData.val() === 20000)" },
        "pot": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "economySettled": { ".validate": "newData.isBoolean()" },
        "economyRewards": { ".validate": true },
        "status": { ".validate": "newData.val() === 'waiting' || newData.val() === 'ready' || newData.val() === 'preview' || newData.val() === 'playing' || newData.val() === 'finished' || newData.val() === 'searching'" },
        "players": {
          "$uid": {
            ".validate": "newData.hasChildren(['uid', 'name', 'score', 'seat']) && newData.child('uid').val() === $uid",
            "uid": { ".validate": "newData.isString() && newData.val() === $uid" },
            "name": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 30" },
            "avatar": { ".validate": "newData.isString() && newData.val().length <= 120" },
            "score": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 8" },
            "wager": { ".validate": "newData.isNumber() && newData.val() >= 0" },
            "seat": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1" },
            "$other": { ".validate": false }
          }
        },
        "current": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1" },
        "cards": { ".validate": true },
        "flipped": { ".validate": true },
        "matched": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 8" },
        "intentos": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "round": { ".validate": "newData.isNumber() && newData.val() >= 1" },
        "roundWins": { ".validate": true },
        "suddenDeath": { ".validate": "newData.isBoolean()" },
        "suddenDeathStep": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "suddenDeathLead": { ".validate": "newData.isNumber() && newData.val() >= -1 && newData.val() <= 1" },
        "matchOver": { ".validate": "newData.isBoolean()" },
        "resolving": { ".validate": "newData.isBoolean()" },
        "statusText": { ".validate": "newData.isString() && newData.val().length <= 160" },
        "hostUid": { ".validate": "newData.isString()" },
        "winnerUid": { ".validate": "newData.isString()" },
        "winnerName": { ".validate": "newData.isString() && newData.val().length <= 30" },
        "concededBy": { ".validate": "newData.isString()" },
        "createdAt": { ".validate": "newData.isNumber() && newData.val() <= now + 300000" },
        "updatedAt": { ".validate": "newData.isNumber() && newData.val() <= now + 300000" },
        "startedAt": { ".validate": "newData.isNumber() && newData.val() <= now + 300000" },
        "$other": { ".validate": false }
      }
    }
  }
}
